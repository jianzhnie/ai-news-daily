# AI News Aggregator — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Anthropic API Key (for Claude mode, default provider)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key (for ChatGPT mode, use --provider openai)
OPENAI_API_KEY=sk-...

# RSSHub port (optional, default 1200)
# RSSHUB_PORT=1200
