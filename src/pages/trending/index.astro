---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";

const entries = await getCollection("trending");
const sorted = entries.sort(
  (a, b) => b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime()
);
---

<Layout title="GitHub Trending - AI News Daily">
  <h2 class="text-accent mb-6 text-xl font-bold">GitHub Trending 中文解读</h2>
  <div class="space-y-4">
    {sorted.map(entry => (
      <a
        href={`/trending/${entry.id}/`}
        class="border-border hover:border-accent block rounded-lg border p-4 transition-colors"
      >
        <div class="text-accent font-medium">{entry.data.title}</div>
        <div class="text-muted-foreground mt-1 flex items-center gap-3 text-sm">
          <span>{entry.data.pubDatetime.toLocaleDateString("zh-CN")}</span>
          {entry.data.description && <span>— {entry.data.description}</span>}
        </div>
      </a>
    ))}
  </div>
</Layout>
