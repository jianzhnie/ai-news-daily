---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";

const entries = await getCollection("daily");
const sorted = entries.sort(
  (a, b) => b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime()
);
---

<Layout title="日报 - AI News Daily">
  <h2 class="text-accent mb-6 text-xl font-bold">AI 日报</h2>
  <div class="space-y-4">
    {sorted.map(entry => (
      <a
        href={`/daily/${entry.id}/`}
        class="border-border hover:border-accent block rounded-lg border p-4 transition-colors"
      >
        <div class="text-accent font-medium">{entry.data.title}</div>
        <div class="text-muted-foreground mt-1 flex items-center gap-3 text-sm">
          <span>{entry.data.pubDatetime.toLocaleDateString("zh-CN")}</span>
          {entry.data.description && <span>— {entry.data.description}</span>}
        </div>
        {entry.data.tags.length > 0 && (
          <div class="mt-2 flex flex-wrap gap-1.5">
            {entry.data.tags.map(tag => (
              <span class="bg-muted text-muted-foreground rounded px-1.5 py-0.5 text-xs">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</Layout>
